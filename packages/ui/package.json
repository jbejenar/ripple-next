{
  "name": "@ripple-next/ui",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./nuxt": "./nuxt.ts"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.13",
    "@nuxt/kit": "^3.15.4"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "@nuxt/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.4",
    "vue": "^3.5.13",
    "@nuxt/kit": "^3.15.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "main": "./dist/ripple-ui.js",
    "types": "./dist/ripple-ui.d.ts",
    "exports": {
      ".": {
        "types": "./dist/ripple-ui.d.ts",
        "import": "./dist/ripple-ui.js"
      },
      "./nuxt": {
        "types": "./dist/nuxt.d.ts",
        "import": "./dist/nuxt.js"
      },
      "./style.css": "./dist/style.css"
    }
  }
}
