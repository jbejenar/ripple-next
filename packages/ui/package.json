{
  "name": "@ripple-next/ui",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./nuxt": "./nuxt.ts"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^3.15.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "main": "./dist/ripple-ui.js",
    "exports": {
      ".": {
        "import": "./dist/ripple-ui.js"
      },
      "./nuxt": {
        "import": "./dist/nuxt.js"
      },
      "./style.css": "./dist/style.css"
