{
  "name": "@ripple-next/shared",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
